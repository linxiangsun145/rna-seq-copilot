<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>RNA-seq Copilot Report</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; color: #1a1a2e; background: #f8fafc; }
    .wrapper { max-width: 960px; margin: 0 auto; padding: 40px 24px; }
    h1 { font-size: 2rem; font-weight: 700; color: #1e40af; margin-bottom: 4px; }
    h2 { font-size: 1.2rem; font-weight: 600; border-bottom: 2px solid #e2e8f0; padding-bottom: 6px; margin: 32px 0 12px; color: #1e293b; }
    h3 { font-size: 1rem; font-weight: 600; color: #334155; margin-bottom: 6px; }
    p { line-height: 1.7; color: #475569; font-size: 0.95rem; }
    .meta { font-size: 0.8rem; color: #94a3b8; margin-bottom: 32px; }
    .cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 16px; margin-bottom: 24px; }
    .card { background: white; border-radius: 12px; border: 1px solid #e2e8f0; padding: 16px; }
    .card-label { font-size: 0.75rem; text-transform: uppercase; color: #94a3b8; margin-bottom: 4px; }
    .card-value { font-size: 1.6rem; font-weight: 700; }
    .up { color: #dc2626; }
    .down { color: #2563eb; }
    .green { color: #16a34a; }
    .plots { display: grid; grid-template-columns: repeat(auto-fit, minmax(380px, 1fr)); gap: 20px; margin-bottom: 24px; }
    .plot-box { background: white; border-radius: 12px; border: 1px solid #e2e8f0; overflow: hidden; }
    .plot-box-title { padding: 10px 16px; font-size: 0.85rem; font-weight: 600; border-bottom: 1px solid #e2e8f0; }
    .plot-box img { width: 100%; display: block; }
    .ai-section { background: linear-gradient(135deg, #f0f4ff, #faf0fe); border: 1px solid #c7d2fe; border-radius: 12px; padding: 24px; margin-bottom: 24px; }
    .ai-block { background: white; border-radius: 8px; padding: 14px; margin-top: 12px; border: 1px solid #e2e8f0; }
    .ai-block h3 { color: #4f46e5; margin-bottom: 8px; }
    .warn-box { background: #fffbeb; border: 1px solid #fbbf24; border-radius: 8px; padding: 12px 16px; margin-bottom: 12px; }
    .warn-box li { font-size: 0.85rem; color: #92400e; margin-left: 16px; list-style: disc; }
    .tag { display: inline-block; padding: 2px 10px; background: #dbeafe; color: #1e40af; border-radius: 999px; font-size: 0.78rem; font-family: monospace; margin: 2px; }
    .methods-box { background: white; border-radius: 8px; border: 1px solid #e2e8f0; padding: 16px; font-size: 0.9rem; color: #475569; line-height: 1.8; }
    .footer { text-align: center; font-size: 0.75rem; color: #94a3b8; margin-top: 48px; padding-top: 16px; border-top: 1px solid #e2e8f0; }
  </style>
</head>
<body>
<div class="wrapper">

  <h1>RNA-seq Copilot Report</h1>
  <p class="meta">Generated: {{ generated_at }} · Job ID: {{ job_id }}</p>

  <!-- Summary cards -->
  <div class="cards">
    <div class="card">
      <div class="card-label">Samples</div>
      <div class="card-value green">{{ summary.n_samples }}</div>
    </div>
    <div class="card">
      <div class="card-label">Contrast</div>
      <div class="card-value" style="font-size:0.85rem; font-weight:600; padding-top:6px; word-break:break-all; line-height:1.4;">
        {% set parts = summary.contrast.split('_vs_') %}
        {% if parts|length == 3 %}
          {{ parts[0] }}: <span class="up">{{ parts[1] }}</span> vs <span class="down">{{ parts[2] }}</span>
        {% else %}
          {{ summary.contrast }}
        {% endif %}
      </div>
    </div>
    <div class="card">
      <div class="card-label">Upregulated DEGs</div>
      <div class="card-value up">{{ summary.deg_up }}</div>
    </div>
    <div class="card">
      <div class="card-label">Downregulated DEGs</div>
      <div class="card-value down">{{ summary.deg_down }}</div>
    </div>
    <div class="card">
      <div class="card-label">PCA Separation</div>
      <div class="card-value" style="font-size:1.1rem; text-transform:capitalize; padding-top:4px;">{{ summary.pca_separation }}</div>
    </div>
  </div>

  <!-- Warnings -->
  {% if summary.warnings or summary.data_issues %}
  <h2>Quality Warnings</h2>
  {% if summary.warnings %}
  <div class="warn-box">
    <strong>Warnings:</strong>
    <ul>{% for w in summary.warnings %}<li>{{ w }}</li>{% endfor %}</ul>
  </div>
  {% endif %}
  {% if summary.data_issues %}
  <div class="warn-box" style="background:#fef2f2; border-color:#f87171;">
    <strong>Data Issues:</strong>
    <ul style="color:#991b1b;">{% for w in summary.data_issues %}<li>{{ w }}</li>{% endfor %}</ul>
  </div>
  {% endif %}
  {% endif %}

  <!-- Strict QC summary -->
  {% if qc %}
  <h2>Strict QC & Validation</h2>
  <div class="warn-box" style="background:#fef2f2; border-color:#ef4444;">
    <strong>Critical Issues ({{ qc.qc_critical|length }}):</strong>
    <ul>{% for w in qc.qc_critical %}<li>{{ w }}</li>{% endfor %}</ul>
  </div>
  <div class="warn-box">
    <strong>Warnings ({{ qc.qc_warnings|length }}):</strong>
    <ul>{% for w in qc.qc_warnings %}<li>{{ w }}</li>{% endfor %}</ul>
  </div>
  <p style="margin-top:8px; font-size:0.9rem;">
    Group balance: <strong>{{ qc.group_balance.status }}</strong>
    (ratio={{ "%.3f"|format(qc.group_balance.ratio) }}),
    PCA variance: PC1={{ "%.2f"|format(100 * qc.pca_variance.PC1) }}%,
    PC2={{ "%.2f"|format(100 * qc.pca_variance.PC2) }}%.
  </p>
  {% endif %}

  <!-- Top genes -->
  <h2>Top Differentially Expressed Genes</h2>
  <p style="margin-bottom:10px;">Genes ranked by adjusted p-value (padj &lt; 0.05):</p>
  <div>{% for g in summary.top_genes %}<span class="tag">{{ g }}</span>{% endfor %}</div>

  <!-- Figures -->
  <h2>Figures</h2>
  <div class="plots">
    {% if plots.pca %}
    <div class="plot-box">
      <div class="plot-box-title">PCA Plot</div>
      <img src="data:image/png;base64,{{ plots.pca }}" alt="PCA plot" />
    </div>
    {% endif %}
    {% if plots.volcano %}
    <div class="plot-box">
      <div class="plot-box-title">Volcano Plot</div>
      <img src="data:image/png;base64,{{ plots.volcano }}" alt="Volcano plot" />
    </div>
    {% endif %}
    {% if plots.ma %}
    <div class="plot-box">
      <div class="plot-box-title">MA Plot</div>
      <img src="data:image/png;base64,{{ plots.ma }}" alt="MA plot" />
    </div>
    {% endif %}
    {% if plots.heatmap %}
    <div class="plot-box">
      <div class="plot-box-title">Sample Distance Heatmap</div>
      <img src="data:image/png;base64,{{ plots.heatmap }}" alt="Heatmap" />
    </div>
    {% endif %}
    {% if plots.sample_distance_heatmap %}
    <div class="plot-box">
      <div class="plot-box-title">QC: Sample Distance Heatmap</div>
      <img src="data:image/png;base64,{{ plots.sample_distance_heatmap }}" alt="QC distance heatmap" />
    </div>
    {% endif %}
    {% if plots.sample_correlation_heatmap %}
    <div class="plot-box">
      <div class="plot-box-title">QC: Sample Correlation Heatmap</div>
      <img src="data:image/png;base64,{{ plots.sample_correlation_heatmap }}" alt="QC correlation heatmap" />
    </div>
    {% endif %}
    {% if plots.library_size %}
    <div class="plot-box">
      <div class="plot-box-title">QC: Library Size</div>
      <img src="data:image/png;base64,{{ plots.library_size }}" alt="QC library size" />
    </div>
    {% endif %}
    {% if plots.count_distribution %}
    <div class="plot-box">
      <div class="plot-box-title">QC: Count Distribution</div>
      <img src="data:image/png;base64,{{ plots.count_distribution }}" alt="QC count distribution" />
    </div>
    {% endif %}
    {% if plots.zero_fraction %}
    <div class="plot-box">
      <div class="plot-box-title">QC: Zero Fraction</div>
      <img src="data:image/png;base64,{{ plots.zero_fraction }}" alt="QC zero fraction" />
    </div>
    {% endif %}
  </div>

  <!-- AI Interpretation -->
  {% if llm %}
  <h2>AI Biological Interpretation</h2>
  <div class="ai-section">
    <p style="font-size:0.8rem; color:#6d28d9; margin-bottom:4px;">Generated from structured summary JSON · Always verify claims independently.</p>
    {% for key, label in [('pca_text','PCA Interpretation'), ('deg_summary','DEG Summary'), ('biological_insights','Biological Insights'), ('data_quality','Data Quality'), ('next_steps','Recommended Next Steps')] %}
    <div class="ai-block">
      <h3>{{ label }}</h3>
      <p>{{ llm[key] }}</p>
    </div>
    {% endfor %}
  </div>
  {% endif %}

  <!-- Methods -->
  <h2>Methods</h2>
  <div class="methods-box">
    Raw gene counts were loaded and quality-checked for sample name consistency, integer values,
    and minimum replicate requirements. Differential expression analysis was performed using
    DESeq2 with design formula "~ {{ summary.contrast.split('_vs_')[0] }}".
    Low-count genes (sum &lt; 10 across all samples) were filtered prior to analysis.
    Variance-stabilising transformation (VST) was applied for visualisations.
    Significant DEGs were defined as |log2FC| &gt; 1 and adjusted p-value (Benjamini–Hochberg) &lt; 0.05.
    All plots were generated using ggplot2 and pheatmap in R.
    Biological interpretation was generated by an LLM from a structured summary JSON — no raw data was provided to the model.
  </div>

  <div class="footer">RNA-seq Copilot MVP · Analysis for research purposes only</div>
</div>
</body>
</html>
